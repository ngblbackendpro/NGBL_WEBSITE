# Force HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Force www or non-www (choose one)
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Redirect www to non-www
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>

# Cache Control for Favicon and Images
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Favicon - Cache for 1 year
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 0 seconds"
    ExpiresByType text/javascript "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
    
    # HTML - disable cache so content updates appear immediately
    ExpiresByType text/html "access plus 0 seconds"
    
    # Web fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
</IfModule>

# Disable cache for social media crawlers (helps with preview updates)
<IfModule mod_headers.c>
    # For Facebook, WhatsApp, LinkedIn crawlers - no cache
    SetEnvIf User-Agent "facebookexternalhit" SOCIAL_CRAWLER
    SetEnvIf User-Agent "Facebot" SOCIAL_CRAWLER
    SetEnvIf User-Agent "Twitterbot" SOCIAL_CRAWLER
    SetEnvIf User-Agent "LinkedInBot" SOCIAL_CRAWLER
    SetEnvIf User-Agent "WhatsApp" SOCIAL_CRAWLER
    SetEnvIf User-Agent "Slackbot" SOCIAL_CRAWLER
    
    Header set Cache-Control "no-cache, no-store, must-revalidate" env=SOCIAL_CRAWLER
    Header set Pragma "no-cache" env=SOCIAL_CRAWLER
    Header set Expires "0" env=SOCIAL_CRAWLER

    # Force fresh HTML/CSS/JS responses to avoid stale browser cache
    <FilesMatch "\.(html|htm|css|js|webmanifest)$">
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
    </FilesMatch>
    
    # Security Headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Allow social media crawlers to access images
    Header set Access-Control-Allow-Origin "*"
</IfModule>

# Compress Text Files
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Custom Error Pages (Optional)
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# Prevent Directory Browsing
Options -Indexes

# File Access Protection
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|inc|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
